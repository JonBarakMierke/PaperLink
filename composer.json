{
    "name": "jon-mierke/paperlink",
    "description": "Request anayltics, trackable links, qr code generator",
    "keywords": [
        "jon-mierke",
        "laravel",
        "paperlink"
    ],
    "homepage": "https://github.com/JonBarakMierke/laravel-request-analytics",
    "license": "MIT",
    "authors": [
        {
            "name": "Jon Mierke",
            "email": "jon@pubplus.net",
            "role": "Developer - Forked Package"
        }
    ],
    "require": {
        "php": "^8.1 | ^8.2 | ^8.3 | ^8.4 | ^8.5",
        "illuminate/contracts": "^10.0 | ^11.0 | ^12.0 | ^13.0",
        "spatie/laravel-package-tools": "^1.16.0",
        "owen-it/laravel-auditing": "^14.0",
        "spatie/laravel-activitylog": "^4.12"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^7.8 | ^8.1",
        "orchestra/workbench": "^8.0 | ^9.0 | ^10.0 | ^11.0",
        "phpunit/phpunit": "^10.5 | ^11.0 | ^12.0",
        "rector/rector": "^2.1.7"
    },
    "autoload": {
        "psr-4": {
            "JonMierke\\PaperLink\\": "src/",
            "JonMierke\\PaperLink\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JonMierke\\PaperLink\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "clear": "@php vendor/bin/testbench package:purge-laravel-request-analytics --ansi",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "build": [
            "@composer run prepare",
            "@php vendor/bin/testbench workbench:build --ansi"
        ],
        "start": [
            "Composer\\Config::disableProcessTimeout",
            "@composer run build",
            "@php vendor/bin/testbench serve"
        ],
        "refactor": "vendor/bin/rector process --dry-run",
        "refactor-fix": "vendor/bin/rector process",
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "JonMierke\\PaperLink\\PaperLinkServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
